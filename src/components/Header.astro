---
import HeartIcon from "@/icons/heart.svg";
---

<header
  class="border-border bg-background/50 sticky top-0 z-50 flex w-full items-center justify-center border p-4 backdrop-blur-sm md:p-5"
>
  <div class="container flex w-full items-center justify-between">
    <a href="/" class="text-primary text-2xl font-bold">Fundación JM</a>

    <nav class="flex items-center gap-2">
      <a
        class="btn btn-md btn-ghost text-fluid-base hidden scale-none font-medium hover:scale-none lg:inline-flex"
        href="#inicio">Inicio</a
      >
      <a
        class="btn btn-md btn-ghost text-fluid-base hidden scale-none font-medium hover:scale-none lg:inline-flex"
        href="#nosotros">Nosotros</a
      >
      <a
        class="btn btn-md btn-ghost text-fluid-base hidden scale-none font-medium hover:scale-none lg:inline-flex"
        href="#contacto">Contacto</a
      >
      <a href="/donar" class="btn btn-primary btn-md text-fluid-base">
        Donar Ahora
        <HeartIcon />
      </a>
    </nav>
  </div>
</header>
